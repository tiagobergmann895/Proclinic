generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id              String           @id @default(cuid())
  name            String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  memberships     UserMembership[]
  patients        Patient[]
  professionals   Professional[]
  appointments    Appointment[]
  clinicalRecords ClinicalRecord[]
  invoices        Invoice[]
  transactions    Transaction[]
  products        Product[]
  stockMovements  StockMovement[]
  sadtGuides      SadtGuide[]
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  password      String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  memberships   UserMembership[]
  professionals Professional[]
}

model UserMembership {
  id       String @id @default(cuid())
  userId   String
  tenantId String
  role     String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId])
}

model Patient {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  name      String
  email     String?
  phone     String?
  cpf       String?
  birthDate DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  appointments    Appointment[]
  clinicalRecords ClinicalRecord[]
  invoices        Invoice[]
  sadtGuides      SadtGuide[]

  @@index([tenantId])
}

model Professional {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  name      String
  specialty String?
  docNumber String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments    Appointment[]
  clinicalRecords ClinicalRecord[]
  sadtGuides      SadtGuide[]

  @@index([tenantId])
}

model Appointment {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id])
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])

  date     DateTime
  duration Int      @default(30)
  status   String   @default("SCHEDULED")
  type     String   @default("CONSULTATION")
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([patientId])
  @@index([professionalId])
}

model ClinicalRecord {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id])
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])

  date    DateTime @default(now())
  type    String   @default("ANAMNESIS")
  content String
  signed  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([patientId])
}

model Invoice {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  
  description String
  amount      Float
  status      String   @default("PENDING") // PENDING, PAID, CANCELLED
  dueDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions Transaction[]

  @@index([tenantId])
  @@index([patientId])
}

model Transaction {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  invoiceId   String?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  
  description String
  amount      Float
  type        String   @default("INCOME") // INCOME, EXPENSE
  method      String   @default("PIX") // PIX, CREDIT_CARD, CASH
  status      String   @default("COMPLETED")
  date        DateTime @default(now())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([invoiceId])
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  
  name        String
  description String?
  category    String   @default("CLINICAL") // CLINICAL, OFFICE, SURGICAL
  unit        String   @default("UN") // UN, BOX, LITER, GRAM
  minStock    Int      @default(10)
  currentStock Int     @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movements   StockMovement[]

  @@index([tenantId])
}

model StockMovement {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  type        String   // IN, OUT
  quantity    Int
  reason      String   // PURCHASE, USAGE, EXPIRATION, ADJUSTMENT
  date        DateTime @default(now())
  batchNumber String?
  expiryDate  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([productId])
}

model SadtGuide {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id])
  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])

  guideNumber       String   @default(cuid())
  requestDate       DateTime @default(now())
  insurerName       String   @default("Particular")
  insurerCard       String?
  cid10             String?
  clinicalIndication String?
  procedures        Json     @default("[]")
  observations      String?
  status            String   @default("PENDING") // PENDING, EXECUTED, CANCELLED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([patientId])
  @@index([professionalId])
}
